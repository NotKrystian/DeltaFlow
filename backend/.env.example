# Hyperliquid testnet (998) — copy to `backend/.env`:
#   cp backend/.env.example backend/.env
#
# After `forge script ... DeployAll ... --broadcast`, run:
#   python3 scripts/sync_env_from_broadcast.py
# That merges pool/vault/escrow addresses from `broadcast/DeployAll.s.sol/<chain>/run-latest.json`.
# You normally only tune RPC, poll intervals, and CORS below.

# JSON-RPC for eth_chainId, eth_getLogs, eth_call (swap indexer + escrow reads)
EVM_RPC_HTTP_URL=https://rpc.hyperliquid-testnet.xyz/evm
CHAIN_ID=998

# Swap log indexer: HTTP eth_getLogs every SWAP_POLL_INTERVAL_S (no WebSocket)
SWAP_POLL_INTERVAL_S=30
# First boot only: blocks behind head to scan for Swap logs (0 = current head only)
SWAP_LOG_LOOKBACK_BLOCKS=0
# Optional: max blocks per eth_getLogs request if the RPC caps range
# MAX_GET_LOGS_BLOCK_RANGE=2000

# Primary USDC/PURR stack (filled by sync from DeployAll broadcast)
SOVEREIGN_VAULT=
WATCH_POOL=
USDC_ADDRESS=0x2B3370eE501B4a559b57D449569354196457D8Ab
PURR_ADDRESS=

# HedgeEscrow for the primary stack — backend polls canClaimBuy / trades (not HL API orders)
HEDGE_ESCROW=
# Core token index for the pool base asset (PURR); filled by sync or cast call HedgeEscrow
PURR_TOKEN_INDEX=

ESCROW_POLL_INTERVAL_S=4
# JSON-RPC: longer timeout + retries helps public RPC rate limits / "Request exceeds defined limit"
# RPC_HTTP_TIMEOUT_S=45
# RPC_CALL_RETRIES=5
# Only poll the last N hedge trade ids per cycle (reduces eth_call volume)
# MAX_ESCROW_TRADES_POLL=200
# ESCROW_INTER_CALL_SLEEP_S=0

PORT=3000
DEBUG=true
# Frontend dev server origin(s) for CORS (run Next on another port, e.g. `next dev -p 3001`, when API uses 3000)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Notes:
# - Vault per-swap PERP hedges run inside the user’s swap tx; this service does not submit them.
# - A second USDC/WETH deploy does not add extra backend vars today; the API still watches WATCH_POOL (primary).
