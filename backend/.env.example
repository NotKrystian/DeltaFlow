# Hyperliquid testnet (998) — copy to `backend/.env`
# After `forge script DeployAll`, run `python3 scripts/sync_env_from_broadcast.py` (or `./scripts/deploy_all_testnet.sh`).

ALCHEMY_WSS_URL=wss://...
EVM_RPC_HTTP_URL=https://rpc.hyperliquid-testnet.xyz/evm
CHAIN_ID=998

# Primary USDC/base stack (required)
SOVEREIGN_VAULT=
WATCH_POOL=
USDC_ADDRESS=0x2B3370eE501B4a559b57D449569354196457D8Ab
PURR_ADDRESS=

# Core hedging — required (one HedgeEscrow per `DeployAll` stack; backend tracks the primary pool’s escrow)
HEDGE_ESCROW=
# Decimal Core token index for the pool base asset (from deploy log `PURR_TOKEN_INDEX=` or HedgeEscrow constructor)
PURR_TOKEN_INDEX=

ESCROW_POLL_INTERVAL_S=4

PORT=8000
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# HedgeEscrow: on-chain CoreWriter spot orders — backend polls claims; not HL API wallet execution.
# Vault per-swap PERP hedges (`SovereignVault.processSwapHedge`) run in the swap tx — no backend action.
