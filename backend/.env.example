# Hyperliquid testnet (998) — copy to `backend/.env`
# After `forge script DeployAll`, paste values from the deploy log ("copy to backend .env" / NEXT_PUBLIC block).

ALCHEMY_WSS_URL=wss://...
EVM_RPC_HTTP_URL=https://rpc.hyperliquid-testnet.xyz/evm
CHAIN_ID=998

# Primary USDC/PURR stack (required for server startup)
SOVEREIGN_VAULT=
WATCH_POOL=
USDC_ADDRESS=0x2B3370eE501B4a559b57D449569354196457D8Ab
PURR_ADDRESS=0xa9056c15938f9aff34CD497c722Ce33dB0C2fD57

# Optional: second stack addresses (documentation only — server watches one pool)
# VAULT_WETH=
# POOL_WETH=

# Optional DeltaFlow / analytics (not required by server.py today)
# FEE_SURPLUS=
# DELTAFLOW_RISK_ENGINE=

# ─── Hedge escrow (CoreWriter status API) ───
# Deploy with DEPLOY_HEDGE_ESCROW=true or HedgeEscrow-only script.
HEDGE_ESCROW=0x0000000000000000000000000000000000000000
# Must match deploy log "BASE_TOKEN_INDEX (backend PURR_TOKEN_INDEX)=" — from PrecompileLib.getTokenIndex(base), NOT perp meta id.
PURR_TOKEN_INDEX=

ESCROW_POLL_INTERVAL_S=4

PORT=8000
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Hedging is on-chain via CoreWriter (`HedgeEscrow`). Do not set HL API keys for execution.
