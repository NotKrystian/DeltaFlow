# ─── Required ───
ALCHEMY_WSS_URL=wss://...
EVM_RPC_HTTP_URL=https://rpc.hyperliquid-testnet.xyz/evm
CHAIN_ID=998

SOVEREIGN_VAULT=0x_your_vault
USDC_ADDRESS=0x2B3370eE501B4a559b57D449569354196457D8Ab
PURR_ADDRESS=0x_your_purr
WATCH_POOL=0x_your_pool

# ─── Hedge escrow (CoreWriter status API) ───
# Deploy: forge script contracts/script/DeployHedgeEscrow.s.sol:DeployHedgeEscrow --rpc-url ... --broadcast
# Or full stack with: DEPLOY_HEDGE_ESCROW=true (and optional SKIP_HL_AGENT=true) in DeployAll.
HEDGE_ESCROW=0x_deployed_hedge_escrow
# Must match deploy log "PURR_TOKEN_INDEX (backend)=" — Core token index from PrecompileLib.getTokenIndex(PURR), NOT perp universe id (e.g. 125).
PURR_TOKEN_INDEX=

ESCROW_POLL_INTERVAL_S=4

# ─── Server ───
PORT=8000
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Removed: HL API execution ───
# Hedging is on-chain via CoreWriter (`HedgeEscrow`). Do not set HL_SECRET_KEY for execution.
