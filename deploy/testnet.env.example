# =============================================================================
# DeltaFlow — copy to repo-root `.env`:   cp deploy/testnet.env.example .env
# Mirror: `.env.example` at repo root (keep both in sync when changing defaults)
# =============================================================================
#
# Hyperliquid HyperEVM testnet — Forge / DeployAll environment template
#
# Same content as `.env.example` at the repo root. Copy either file to `.env`:
#   cp deploy/testnet.env.example .env
#   # or: cp .env.example .env
#
# RPC: https://rpc.hyperliquid-testnet.xyz/evm   Chain ID: 998
# Asset indices: docs/deployment/testnet-asset-ids.md
# Full workflow: docs/getting-started/full-stack-runbook.md
#
# Deploy: ./scripts/deploy_all_testnet.sh
#   (uses TESTNET_RPC_URL / RPC_URL; optional FORK_BLOCK; default --slow on every forge broadcast)
# Optional: DEPLOY_FAST=1 ./scripts/deploy_all_testnet.sh  (omit --slow; faster but may hit nonce errors on public RPCs)
# After broadcast: python3 scripts/sync_env_from_broadcast.py  →  frontend/.env.local + backend/.env
# Fee-only upgrade (no vault/pool/ALM redeploy): ./scripts/upgrade_fee_module_testnet.sh [primary|weth|both]
# Requires EXISTING_POOL / EXISTING_POOL_WETH below.
#
# REQUIRED on HyperEVM: enable BIG blocks for the deployer (~30M gas for large deployments).
# https://hyperliquid.gitbook.io/hyperliquid-docs/for-developers/hyperevm/dual-block-architecture

# --- RPC / chain (optional overrides) ---
TESTNET_RPC_URL=https://rpc.hyperliquid-testnet.xyz/evm
RPC_URL=
CHAIN_ID=998
# FORK_BLOCK=   # unset = latest block from `cast block-number` inside deploy_all_testnet.sh

# --- Required ---
# Existing pools for fee-only rewires (optional unless using upgrade_fee_module_testnet.sh)
EXISTING_POOL=
EXISTING_POOL_WETH=

# PRIVATE_KEY must be hex with 0x prefix (Forge `vm.envUint` requirement)
PRIVATE_KEY=
POOL_MANAGER=

# Canonical testnet tokens (do not change unless HL docs change)
USDC=0x2B3370eE501B4a559b57D449569354196457D8Ab
PURR=0xa9056c15938f9aff34CD497c722Ce33dB0C2fD57
WETH=0x5a1A1339ad9e52B7a4dF78452D5c18e8690746f3

# Spot / price — run `forge script contracts/script/ReadSpotIndex.s.sol` on testnet with TOKEN0/TOKEN1 set
# Then set SPOT_INDEX_PURR / SPOT_INDEX_WETH to the logged "PURR spotIndex (universe)"
SPOT_INDEX_PURR=
INVERT_PURR_PX=false
SPOT_INDEX_WETH=
INVERT_WETH_PX=false
USE_PERP_PRICE_FOR_QUOTE_PURR=false
USE_PERP_PRICE_FOR_QUOTE_WETH=true

RAW_PX_SCALE=100000000
RAW_PX_SCALE_WETH=100000000

# Pool
PROTOCOL_FACTORY=0x0000000000000000000000000000000000000000
VERIFIER_MODULE=0x0000000000000000000000000000000000000000
DEFAULT_SWAP_FEE_BIPS=15
# Debug: 0 disables swap-fee-module timelock so strategist can rewire repeatedly.
# Launch: set to 259200 (3 days).
SWAP_FEE_MODULE_TIMELOCK_SEC=0

# BalanceSeeking V3 params (used only if DEPLOY_DELTAFLOW_FEE=false)
BASE_FEE_BIPS=15
MIN_FEE_BIPS=5
MAX_FEE_BIPS=1000
LIQUIDITY_BUFFER_BPS=50

# Optional HL agent on vault
SKIP_HL_AGENT=true
HL_AGENT_NAME=hedge-bot
# HL_AGENT_PRIVATE_KEY=

# Second pair in one broadcast
DEPLOY_USDC_WETH=false
# If true, deploy only USDC/WETH (skip USDC/PURR) via runStackWeth().
DEPLOY_ONLY_WETH=false
# When true: ./scripts/deploy_all_testnet.sh runs USDC/PURR first (big blocks), pauses for you to switch
# the deployer to small blocks, then deploys USDC/WETH. Set to 0 to broadcast both stacks in one `run()` (no pause).
# DEPLOY_PAUSE_BETWEEN_STACKS=1

# HedgeEscrow is deployed for every stack (core). No flag.

# Strategist / owner for FeeSurplus + RiskEngine (defaults to deployer)
STRATEGIST=

# --- DeltaFlow fee stack (default ON) ---
DEPLOY_DELTAFLOW_FEE=true
USE_BALANCE_SEEKING_FEE_MODULE=false

# Perp index (Hyperliquid perp universe id for the BASE asset — see docs/deployment/testnet-asset-ids.md)
#
# For full DeployAll / AmmDeployBase (external SovereignVault + pool + on-chain per-swap hedge):
#   Set PERP_INDEX_PURR / PERP_INDEX_WETH to the REAL perp index. The pool and vault both bind to this;
#   forge script will revert if you leave uint32.max here for that deploy path.
#
# Sentinel 4294967295 (uint32 max): skips perp *reads* inside DeltaFlowCompositeFeeModule only — NOT valid
# as the vault/pool hedge pair index when deploying the standard vault-backed stack.
# MUST set real perp universe indices for vault-backed DeployAll (not 4294967295).
PERP_INDEX_PURR=4294967295
PERP_INDEX_WETH=4294967295

# Hedge batching (SovereignVault — see docs/deployment/pairs-and-scripts.md)
USE_MARK_MIN_HEDGE_SZ=true
MIN_PERP_HEDGE_SZ_FLOOR=0
# USE_MARK_MIN_HEDGE_SZ=false + MIN_PERP_HEDGE_SZ_FLOOR=0 → IOC every swap (no queue).
# USE_MARK_MIN_HEDGE_SZ=false + MIN_PERP_HEDGE_SZ_FLOOR>0 → fixed sz threshold (legacy).

# BBO asset for spread check — 0 means auto `10000 + SPOT_INDEX_*`
SPOT_ASSET_BBO_PURR=0
SPOT_ASSET_BBO_WETH=0

CAPACITY_WAD_PURR=1000000000000000000000
CAPACITY_WAD_WETH=1000000000000000000000

SURPLUS_FRACTION_BPS=1000
VOLATILE_REGIME=false
DF_USE_MARKET_RISK_COMPONENT=false
DF_REQUIRE_SURPLUS_NEW_RISK=false

# Risk policy (DeltaFlowRiskEngine)
DF_POLICY_CAPACITY_WAD=0
DF_NAV_SOFT_WAD=0
DF_NAV_WARN_WAD=0
DF_NAV_HARD_WAD=0
DF_MAX_SHORTFALL_WAD=115792089237316195423570985008687907853269984665640564039457584007913129639935
DF_MAX_SPREAD_BPS=0
DF_MIN_SURPLUS_USDC_NEW_RISK=0
DF_RAW_FEE_REJECT_BPS=0
DF_DISPLAYED_FEE_CAP_BPS=300
DF_REQUIRE_SURPLUS_TREND=false

# Fee component defaults (DeltaFlowFeeMath)
DF_EXEC_PERP_BPS=4
DF_EXEC_SPOT_SHORTFALL_BPS=7
DF_DELAY_NORMAL_BPS=2
DF_DELAY_STRESSED_BPS=5
DF_BASIS_MAX_BPS=5
DF_FUNDING_CAP_BPS=8
DF_INV_KAPPA_WAD=2400000000000000000
DF_EXHAUST_LINEAR_WAD=12000000000000000000
DF_EXHAUST_QUAD_WAD=80000000000000000000
DF_SAFETY_BASE_BPS=2
DF_DELAY_STRESSED=false

# HTML quote engine (deltaflow_response.html §7) — impact sqrt, H_MAX util, POOL_NAV bands
DF_PERP_DEPTH_WAD=1500000000000000000000000
DF_IMPACT_COEFF=12
DF_H_MAX_SZ=200000
DF_POOL_NAV_WAD=0
