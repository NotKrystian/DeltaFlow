# Hyperliquid HyperEVM testnet — copy to `.env` at repo root for `forge script`
# RPC: https://rpc.hyperliquid-testnet.xyz/evm   Chain ID: 998
# Asset indices & limit-order ids: docs/deployment/testnet-asset-ids.md
#
# After deploy: ./scripts/deploy_all_testnet.sh  (or: forge script ... --broadcast && python3 scripts/sync_env_from_broadcast.py)
# writes frontend/.env.local and backend/.env from broadcast/DeployAll.s.sol/998/run-latest.json

# --- Required ---
PRIVATE_KEY=
POOL_MANAGER=

# Canonical testnet tokens (do not change unless HL docs change)
USDC=0x2B3370eE501B4a559b57D449569354196457D8Ab
PURR=0xa9056c15938f9aff34CD497c722Ce33dB0C2fD57
WETH=0x5a1A1339ad9e52B7a4dF78452D5c18e8690746f3

# Spot / price — run `forge script contracts/script/ReadSpotIndex.s.sol` on testnet with TOKEN0/TOKEN1 set
# Then set SPOT_INDEX_PURR / SPOT_INDEX_WETH to the logged "PURR spotIndex (universe)"
SPOT_INDEX_PURR=
INVERT_PURR_PX=false
SPOT_INDEX_WETH=
INVERT_WETH_PX=false

RAW_PX_SCALE=100000000
RAW_PX_SCALE_WETH=100000000

# Pool
PROTOCOL_FACTORY=0x0000000000000000000000000000000000000000
VERIFIER_MODULE=0x0000000000000000000000000000000000000000
DEFAULT_SWAP_FEE_BIPS=15

# BalanceSeeking V3 params (used only if DEPLOY_DELTAFLOW_FEE=false)
BASE_FEE_BIPS=15
MIN_FEE_BIPS=5
MAX_FEE_BIPS=1000
LIQUIDITY_BUFFER_BPS=50

# Optional HL agent on vault
SKIP_HL_AGENT=true
HL_AGENT_NAME=hedge-bot
# HL_AGENT_PRIVATE_KEY=

# Second pair in one broadcast
DEPLOY_USDC_WETH=false

# HedgeEscrow per stack
DEPLOY_HEDGE_ESCROW=false

# Strategist / owner for FeeSurplus + RiskEngine (defaults to deployer)
STRATEGIST=

# --- DeltaFlow fee stack (default ON) ---
DEPLOY_DELTAFLOW_FEE=true
USE_BALANCE_SEEKING_FEE_MODULE=false

# Perp: use 4294967295 (uint32 max) to skip perp reads in composite fee module
PERP_INDEX_PURR=4294967295
PERP_INDEX_WETH=4294967295

# BBO asset for spread check — 0 means auto `10000 + SPOT_INDEX_*`
SPOT_ASSET_BBO_PURR=0
SPOT_ASSET_BBO_WETH=0

CAPACITY_WAD_PURR=1000000000000000000000
CAPACITY_WAD_WETH=1000000000000000000000

SURPLUS_FRACTION_BPS=1000
VOLATILE_REGIME=false
DF_REQUIRE_SURPLUS_NEW_RISK=false

# Risk policy (DeltaFlowRiskEngine)
DF_POLICY_CAPACITY_WAD=0
DF_NAV_SOFT_WAD=0
DF_NAV_WARN_WAD=0
DF_NAV_HARD_WAD=0
DF_MAX_SHORTFALL_WAD=115792089237316195423570985008687907853269984665640564039457584007913129639935
DF_MAX_SPREAD_BPS=500
DF_MIN_SURPLUS_USDC_NEW_RISK=0
DF_RAW_FEE_REJECT_BPS=80
DF_DISPLAYED_FEE_CAP_BPS=60
DF_REQUIRE_SURPLUS_TREND=false

# Fee component defaults (DeltaFlowFeeMath)
DF_EXEC_PERP_BPS=4
DF_EXEC_SPOT_SHORTFALL_BPS=7
DF_DELAY_NORMAL_BPS=2
DF_DELAY_STRESSED_BPS=5
DF_BASIS_MAX_BPS=5
DF_FUNDING_CAP_BPS=8
DF_INV_KAPPA_WAD=2400000000000000000
DF_EXHAUST_LINEAR_WAD=12000000000000000000
DF_EXHAUST_QUAD_WAD=80000000000000000000
DF_SAFETY_BASE_BPS=2
DF_DELAY_STRESSED=false
